{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Flutter Windows (Debug)",
      "runtimeExecutable": "flutter",
      "runtimeArgs": ["run", "-d", "windows"],
      "port": 0
    },
    {
      "name": "Flutter Web (Chrome)",
      "runtimeExecutable": "flutter",
      "runtimeArgs": ["run", "-d", "chrome", "--web-port", "8080"],
      "port": 8080
    },
    {
      "name": "Flutter macOS (Debug)",
      "runtimeExecutable": "flutter",
      "runtimeArgs": ["run", "-d", "macos"],
      "port": 0
    },
    {
      "name": "Flutter Linux (Debug)",
      "runtimeExecutable": "flutter",
      "runtimeArgs": ["run", "-d", "linux"],
      "port": 0
    }
  ]
}
